# YouTube Data API v3（可以填多个，逗号分隔，配额耗尽自动轮换下一个）
YOUTUBE_API_KEYS=
# 兼容旧配置：不设 YOUTUBE_API_KEYS 时会读这个（同样支持逗号分隔多个）
YOUTUBE_API_KEY=

# 飞书应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书多维表格
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# 飞书群机器人 Webhook（卡片推送）
FEISHU_WEBHOOK_URL=

# 可视化看板（GitHub Pages），留空则使用 config.py 中的默认值
DASHBOARD_URL=
